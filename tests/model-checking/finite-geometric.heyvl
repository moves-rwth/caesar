// RUN: @caesar mc --timeout 30 --jani-dir /tmp/caesar-mc-finite-geometric @file

@wp
proc finite_geometric() -> (c: UInt, cont: Bool)
    post [!cont]
{
    c = 0
    cont = true
    while cont && c <= 20 {
        var prob_choice: Bool = flip(0.5)
        if prob_choice {
            cont = false
        } else {
            c = c + 1
        }
    }
}
