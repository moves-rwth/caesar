// RUN: @caesar mc --timeout 30 --jani-skip-quant-pre --jani-dir /tmp/caesar-mc-bounded-linear-runtime @file

// Finite-state model-checking variant of tests/loop-rules/induction/linear01.heyvl.
@ert
coproc bounded_linear(init_x: UInt) -> (x: UInt)
    pre 0.6 * init_x
    post 0
{
    x = init_x
    while 2 <= x {
        var prob_choice: Bool = flip(1/3)
        if prob_choice {
            x = x - 1
        } else {
            x = x - 2
        }
        tick 1
    }
}
