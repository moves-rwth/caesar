
// In Section 3.3. of the Barros paper, they claim that their algorithms that do either forwards OR backwards
// reasoning cannot slice in the following program. We can.

proc program6(y: Int) -> (x: Int)
    pre ?(true)
    post ?(x >= 0)
{
    @slice_verify {
        x = x * x
        x = x + 100 // sliced
        x = x + 50 // sliced
    }
}