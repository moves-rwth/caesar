// RUN: env RUST_LOG=info,z3=error @caesar @file --timing --print-core-procs --print-theorem --z3-probe --z3-stats --z3-qi-profile --z3-mbqi-trace

proc omega(init_x: UInt) -> (x: UInt)
    pre init_x
    post 0
{
    x = init_x

    @omega_invariant(n, [x<=n] * x)
    while 0 <= x {
        tick 1
        x = x - 1
    }
}
